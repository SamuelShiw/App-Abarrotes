<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvDetalleProductoId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Producto ID: 1"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvDetalleCantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cantidad: 2"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDetallePrecio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="P. Unitario: S/ 5.50"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDetalleSubtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subtotal: S/ 11.00"
        android:textSize="14sp" />

</LinearLayout>