<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvNombreAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Administrador:"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRolAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rol: ADMINISTRADOR"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTituloPanelAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="Panel del Administrador"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnModuloTrabajadores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gestionar Trabajadores" />

            <Button
                android:id="@+id/btnModuloUsuarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gestionar Usuarios" />

            <Button
                android:id="@+id/btnModuloProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gestionar Productos" />

            <Button
                android:id="@+id/btnModuloSecciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gestionar Secciones" />

            <Button
                android:id="@+id/btnModuloEstantes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gestionar Estantes" />

            <Button
                android:id="@+id/btnModuloInventario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Gestionar Inventario" />

            <Button
                android:id="@+id/btnModuloConsultaCaja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Consultar Caja" />

            <Button
                android:id="@+id/btnModuloConsultaReposicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Consultar Reposición" />

            <Button
                android:id="@+id/btnCerrarSesionAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Cerrar sesión" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/fragmentContainerAdmin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>