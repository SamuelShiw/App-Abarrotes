<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar venta"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvLabelProductoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spProductoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvInfoProductoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Precio: S/ 0.00 | Stock estante: 0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvLabelTipoComprobanteVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tipo de comprobante"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spTipoComprobanteVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <EditText
            android:id="@+id/etCantidadVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Cantidad"
            android:inputType="number"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnAgregarProductoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Agregar al carrito"
            android:background="@drawable/bg_button_primary"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/tvTituloCarritoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Carrito"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCarritoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Carrito vacío"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Total: S/ 0.0"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRegistrarVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Confirmar venta"
            android:background="@drawable/bg_button_primary"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnLimpiarCarritoVenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Limpiar carrito" />

    </LinearLayout>

</ScrollView>