<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTipoMovimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo: INGRESO"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black" />

    <TextView
        android:id="@+id/tvCantidadMovimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Cantidad: 10"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvProductoMovimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Producto ID: 1"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvFechaMovimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Fecha: 2026-03-06 10:00"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvObservacionMovimiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Obs: Ajuste inicial"
        android:textSize="14sp" />

</LinearLayout>