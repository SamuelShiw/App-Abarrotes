<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTituloReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reposición de productos"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvLabelProductoReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Producto"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spProductoReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/tvInfoProductoReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Almacén: 0 | Estante: 0"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etCantidadReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="Cantidad a mover"
        android:inputType="number"
        android:background="@drawable/bg_input"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnRegistrarReposicion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Registrar reposición"
        android:background="@drawable/bg_button_primary"
        android:textColor="@android:color/white" />

</LinearLayout>