<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloRegistrarTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar trabajador"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etNombresTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombres"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etApellidosTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Apellidos"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etDniTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="DNI"
            android:inputType="number"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etTelefonoTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Teléfono"
            android:inputType="phone"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etCargoTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Cargo"
            android:background="@drawable/bg_input"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnGuardarTrabajador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Guardar trabajador"
            android:background="@drawable/bg_button_primary"
            android:textColor="@android:color/white" />

    </LinearLayout>

</ScrollView>